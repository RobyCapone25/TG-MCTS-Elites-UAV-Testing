# Output directories
LOGS_COPY_DIR=results/
RESULTS_DIR=results/
TESTS_FOLDER=generated_tests/

# Recommended host execution mode
AGENT=docker
SIMULATOR=ros
SPEED=1
ROBOT=px4_ros
HEADLESS=True

# Aerialist/PX4 configuration
USE_GPS=False
PLOT_TESTS_XYZ=False
ALLIGN_ORIGIN=True
USE_RADIANS=False
LOAD_HOME_FROM_LOG=True

# Pinned simulator image
DOCKER_IMG=skhatiri/aerialist:2.0
DOCKER_TIMEOUT=1000
