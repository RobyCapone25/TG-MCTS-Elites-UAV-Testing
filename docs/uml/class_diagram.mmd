classDiagram
    class CompetitionCLI {
        +arg_parse() Namespace
        +export_ranking(test_cases, ranking_dir)
        +main() int
    }

    class TGMCTSElitesGenerator {
        +generate(budget) List
        -reset_search_state()
        -process_evaluated_node(node, result, budget)
        -run_search_phase(root, attempt_limit, total_budget)
    }

    class RandomGenerator {
        <<compatibility alias>>
    }

    class GeneratorConstants {
        +CRITICAL_PROXIMITY_THRESHOLD
        +FAILURE_THRESHOLD
        +NEAR_MISS_THRESHOLD
        +FINAL_MIN_SCENARIO_DISTANCE
        +FINAL_MIN_TRAJECTORY_DTW
        +OUTPUT_SNAPSHOT_INTERVAL
    }

    class PersistenceMixin {
        -new_run_id() str
        -setup_run_directory(budget)
        -consume_simulation_attempt(budget) int
        -save_result_checkpoint(result, attempt, node) EvalResult
        -save_confirmation_failure_artifacts(result, attempt, node, base_attempt) EvalResult
        -load_previous_results()
        -load_previous_confirmations()
        -load_previous_history()
    }

    class MissionPlanMixin {
        -resolve_mission_plan_path() Path
        -mission_reference_path() List
        -select_simulator_frame(path) Tuple
        -reference_pose_samples() List
    }

    class GeometryMixin {
        -rotated_corners(obstacle) List
        -rotated_boxes_overlap(first, second) bool
    }

    class ValidationMixin {
        -validate_test_case_rules(obstacles) Tuple
        -has_physical_feasible_corridor(obstacles) bool
    }

    class ScenarioMixin {
        -single_blocker() List
        -gate_scenario() List
        -staggered_scenario() List
        -apply_action(obstacles, action) List
    }

    class ArchiveMixin {
        -elite_cell(obstacles) Tuple
        -update_elites(result)
    }

    class ScoringMixin {
        -official_point(distance) int
        -failure_evidence(distance, mission_status) str
        -reward(distance, obstacle_count, time, status) float
        -final_rank_key(result) Tuple
        -is_returnable_failure(result) bool
    }

    class MCTSMixin {
        -ucb_score(parent, child) float
        -progressive_widening_limit(node) int
        -tree_policy(root) MCTSNode
        -backup(node, reward)
    }

    class TrajectoryMixin {
        -extract_trajectory_xy(test) Tuple
        -extract_trajectory_series(test) Tuple
        -mission_completion_status(test) str
    }

    class SimulationMixin {
        -run_simulation_once(node, attempt, budget) EvalResult
        -evaluate_with_retries(node, budget) EvalResult
    }

    class ConfirmationMixin {
        -confirmation_reserve(budget) int
        -confirmation_candidates() List
        -confirm_candidate_once(base, budget) bool
        -confirm_top_failures(budget) bool
    }

    class PlottingMixin {
        -save_scenario_plot(...)
        -save_xy_time_plot(...)
        -save_tree_plot(root)
        -save_progress_plots()
        -save_all_outputs(root)
        -export_best_ranked_summary(test_cases)
    }

    class SelectionMixin {
        -scenario_distance(first, second) float
        -trajectory_distance(first, second) float
        -scenarios_too_similar(first, second) bool
        -final_suite() List
    }

    class TestCase {
        +execute() Trajectory
        +get_distances() List
        +save_yaml(path)
        +log_file
        +plot_file
        +xy_time_plot_file
    }

    class EvalResult {
        +obstacles
        +test
        +min_distance
        +point
        +reward
        +cell
        +mission_status
        +failure_evidence
        +compliance_status
        +artifacts_saved
        +scenario_plot
        +xy_time_plot
        +point_samples
        +distance_samples
        +elapsed_samples
        +confirmation_attempts
    }

    class MCTSNode {
        +obstacles
        +parent
        +children
        +node_id
        +visits
        +total_reward
        +best_reward
        +eval_result
        +mean_reward() float
    }

    class SavedEvaluatedTestCase {
        +yaml_file
        +log_file
        +plot_file
        +xy_time_plot_file
        +failure_evidence
        +save_yaml(path)
    }

    GeneratorConstants <|-- TGMCTSElitesGenerator
    PersistenceMixin <|-- TGMCTSElitesGenerator
    GeometryMixin <|-- TGMCTSElitesGenerator
    MissionPlanMixin <|-- TGMCTSElitesGenerator
    ValidationMixin <|-- TGMCTSElitesGenerator
    ScenarioMixin <|-- TGMCTSElitesGenerator
    ArchiveMixin <|-- TGMCTSElitesGenerator
    ScoringMixin <|-- TGMCTSElitesGenerator
    MCTSMixin <|-- TGMCTSElitesGenerator
    TrajectoryMixin <|-- TGMCTSElitesGenerator
    PlottingMixin <|-- TGMCTSElitesGenerator
    SimulationMixin <|-- TGMCTSElitesGenerator
    ConfirmationMixin <|-- TGMCTSElitesGenerator
    SelectionMixin <|-- TGMCTSElitesGenerator

    RandomGenerator ..> TGMCTSElitesGenerator : alias
    CompetitionCLI --> TGMCTSElitesGenerator : constructs and runs
    CompetitionCLI --> TestCase : exports selected tests
    TGMCTSElitesGenerator --> MCTSNode
    TGMCTSElitesGenerator --> EvalResult
    SimulationMixin --> TestCase
    PersistenceMixin --> SavedEvaluatedTestCase
    PersistenceMixin --> EvalResult
    SelectionMixin --> EvalResult
